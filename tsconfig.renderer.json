{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "out/tsc/renderer",
    "rootDir": ".",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "vitest/globals"],
    "jsx": "react-jsx",
    "noEmit": true
  },
  "include": [
    "src/renderer/**/*.ts",
    "src/renderer/**/*.tsx",
    "src/shared/**/*.ts",
    "src/contracts/**/*.ts",
    "tests/renderer/**/*.ts",
    "tests/renderer/**/*.tsx"
  ]
}
