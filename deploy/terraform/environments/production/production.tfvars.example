# Example only — NOT used by CI and NOT auto-loaded by Terraform.
# CI (deploy-production.yml) supplies these via TF_VAR_* repo variables.
# Copy to production.tfvars for a local `terraform plan`/`apply` if you want:
#   terraform plan -var-file=production.tfvars
# (production.tfvars is gitignored; this .example file is committed as documentation.)
project_id = "your-production-project-id"
region     = "europe-west1"
env        = "production"
